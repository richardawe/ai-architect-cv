# ── Required: set these as GitHub repository secrets ───────────────────────
# Settings → Secrets and variables → Actions → New repository secret

# OpenRouter API key — https://openrouter.ai/keys
# Used by:
#   - deploy.yml   → injected into chat-config.js for the browser chat widget
#   - generate-cv.yml → used by scripts/generate_cv.py for CV generation
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx

# ── Optional: GitHub Actions repository variable (not a secret) ─────────────
# Settings → Secrets and variables → Actions → Variables tab
# Default if not set: meta-llama/llama-3.1-8b-instruct:free
CHAT_MODEL=meta-llama/llama-3.1-8b-instruct:free
